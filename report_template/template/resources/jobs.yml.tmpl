resources:
  jobs:
    {{.report_name}}:
      name: {{.report_name}}
      tasks:
        - task_key: report_generation
          environment_key: impulse
          notebook_task:
            notebook_path: ../src/report.py
            base_parameters:
              config_path: "./config/${bundle.target}_config.json"
      environments:
        - environment_key: impulse
          spec:
            client: "5"
            dependencies:
              # Pulls the Impulse framework (package `mda_reporting`) from
              # github.com/databrickslabs/impulse at deploy time. Pin to a tag
              # or commit SHA once the framework starts publishing releases.
              - "mda_reporting @ git+https://github.com/databrickslabs/impulse@main"
      permissions:
        - level: CAN_MANAGE
          group_name: ${var.manage_group}
      parameters:
        - name: reset_report
          default: false
