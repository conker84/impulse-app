resources:
  jobs:
    {{.report_name}}:
      name: {{.report_name}}
      tasks:
        - task_key: report_generation
          environment_key: impulse
          notebook_task:
            notebook_path: ../src/report.py
            base_parameters:
              config_path: "./config/${bundle.target}_config.json"
      environments:
        - environment_key: impulse
          spec:
            client: "5"
            dependencies:
              # Pulls the Impulse framework (PyPI name `databricks-impulse`,
              # import path `impulse_reporting`) from github.com/databrickslabs/impulse
              # at deploy time. Pinned to a commit SHA for reproducibility; bump
              # this when adopting a newer framework version (and re-run any
              # affected report deploys).
              - "databricks-impulse @ git+https://github.com/databrickslabs/impulse@a2340f7"
      permissions:
        - level: CAN_MANAGE
          group_name: ${var.manage_group}
      parameters:
        - name: reset_report
          default: false
