# Frontend source & build tooling (only frontend/dist/ is needed at runtime)
# NOTE: Each entry must be specific — wildcard frontend/* patterns cause
# databricks sync to skip the entire frontend/ tree including frontend/dist/.
frontend/src/
frontend/node_modules/
frontend/package-lock.json
frontend/package.json
frontend/tsconfig.json
frontend/tsconfig.tsbuildinfo
frontend/vite.config.ts
frontend/index.html

# Dev/docs files not needed at runtime
CLAUDE.md
PROJECT.md
README.md

# Python bytecode (regenerated on startup)
__pycache__/
*.pyc

