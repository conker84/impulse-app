resources:
  jobs:
    {{.report_name}}:
      name: {{.report_name}}
      tasks:
        - task_key: pre_processing
          environment_key: impulse
          notebook_task:
            notebook_path: ../src/preprocessing/01_status_pre-processing.ipynb
            base_parameters:
              config_path: "../config/${bundle.target}_config.json"
        - task_key: report_generation
          depends_on:
            - task_key: pre_processing
          environment_key: impulse
          notebook_task:
            notebook_path: ../src/report.py
            base_parameters:
              config_path: "./config/${bundle.target}_config.json"
        - task_key: post_processing
          depends_on:
            - task_key: report_generation
          environment_key: impulse
          notebook_task:
            notebook_path: ../src/postprocessing/01_status_post-processing_success.ipynb
            base_parameters:
              config_path: "../config/${bundle.target}_config.json"
      environments:
        - environment_key: impulse
          spec:
            client: "5"
            dependencies:
              - ../lib/mda_framework_v2-0.0.4-py3-none-any.whl
      permissions:
        - level: CAN_MANAGE
          group_name: ${var.manage_group}
      parameters:
        - name: reset_report
          default: false
        - name: status_table_name
          default: "status"
